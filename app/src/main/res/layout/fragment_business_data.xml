<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:paddingBottom="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Título -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/business_data_title"
                    android:textColor="@color/text_dark"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inclusive_sans" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="24dp"
                    android:text="@string/business_data_description"
                    android:textColor="#9E9E9E"
                    android:textSize="13sp"
                    android:fontFamily="@font/inclusive_sans" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EDE7F6"
                    android:layout_marginBottom="20dp" />

                <!-- Business Picture Picker -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/business_data_photo"
                    android:textColor="@color/deep_purple"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inclusive_sans"
                    android:layout_marginBottom="12dp" />

                <!-- Contenedor de imagen -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardImagePicker"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardCornerRadius="60dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#F8F4FF">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <!-- Imagen seleccionada -->
                            <ImageView
                                android:id="@+id/imgBusinessPicture"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:visibility="gone" />

                            <!-- Placeholder -->
                            <LinearLayout
                                android:id="@+id/layoutPlaceholder"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    app:srcCompat="@drawable/ic_camera"
                                    app:tint="#7640BD" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="@string/business_data_add_photo"
                                    android:textColor="@color/deep_purple"
                                    android:textSize="11sp"
                                    android:fontFamily="@font/inclusive_sans" />
                            </LinearLayout>
                        </FrameLayout>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Tap to upload a photo (optional)"
                        android:textColor="#BDBDBD"
                        android:textSize="11sp"
                        android:fontFamily="@font/inclusive_sans" />

                </LinearLayout>

                <!-- Business Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/business_data_name"
                    android:textColor="@color/deep_purple"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inclusive_sans"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutBusinessName"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxBackgroundColor="#F8F4FF"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/deep_purple"
                    app:hintEnabled="false"
                    app:startIconDrawable="@drawable/ic_business"
                    app:startIconTint="#7640BD">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/txtBusinessName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="@string/business_data_name_hint"
                        android:inputType="text"
                        android:maxLength="50"
                        android:paddingStart="14dp"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:fontFamily="@font/inclusive_sans" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Business Description -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/business_data_business_description"
                    android:textColor="@color/deep_purple"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inclusive_sans"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutBusinessDescription"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:boxBackgroundColor="#F8F4FF"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/deep_purple"
                    app:hintEnabled="false"
                    app:counterEnabled="true"
                    app:counterMaxLength="200">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/txtBusinessDescription"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:hint="@string/business_data_business_description_hint"
                        android:inputType="textMultiLine"
                        android:maxLength="200"
                        android:gravity="top"
                        android:paddingStart="14dp"
                        android:paddingTop="12dp"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:fontFamily="@font/inclusive_sans" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Step indicator -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="32dp"
                        android:layout_height="6dp"
                        android:background="@drawable/step_inactive"
                        android:layout_marginEnd="6dp" />

                    <View
                        android:layout_width="32dp"
                        android:layout_height="6dp"
                        android:background="@drawable/step_inactive"
                        android:layout_marginEnd="6dp" />

                    <View
                        android:layout_width="32dp"
                        android:layout_height="6dp"
                        android:background="@drawable/step_active"
                        android:layout_marginEnd="6dp" />

                    <View
                        android:layout_width="32dp"
                        android:layout_height="6dp"
                        android:background="@drawable/step_inactive" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/business_data_step"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp"
                    android:fontFamily="@font/inclusive_sans"
                    android:layout_marginBottom="20dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNext"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/register_button_next"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/inclusive_sans"
                    app:backgroundTint="#F68031"
                    app:cornerRadius="16dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:text="You can update this information later from your profile"
            android:textColor="#9E9E9E"
            android:textSize="11sp"
            android:fontFamily="@font/inclusive_sans" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
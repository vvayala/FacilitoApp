<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:paddingBottom="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp">

        <!-- Card contenedor -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/account_type_title"
                    android:textColor="@color/text_dark"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inclusive_sans" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="24dp"
                    android:text="@string/account_type_description"
                    android:textColor="#9E9E9E"
                    android:textSize="13sp"
                    android:fontFamily="@font/inclusive_sans" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EDE7F6"
                    android:layout_marginBottom="24dp" />

                <!-- Card: Cliente -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardClient"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#F8F4FF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="20dp">

                        <!-- Icono -->
                        <LinearLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/circle_purple_light"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                app:srcCompat="@drawable/icon_user"
                                app:tint="#7640BD" />
                        </LinearLayout>

                        <!-- Texto -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/account_type_client_role"
                                android:textColor="@color/text_dark"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/inclusive_sans" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/account_type_client_role_description"
                                android:textColor="#9E9E9E"
                                android:textSize="12sp"
                                android:fontFamily="@font/inclusive_sans" />
                        </LinearLayout>

                        <!-- Check indicator -->
                        <ImageView
                            android:id="@+id/checkClient"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:visibility="gone"
                            app:srcCompat="@drawable/ic_check_circle"
                            app:tint="#7640BD" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card: Proveedor -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardProvider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFF4EC">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="20dp">

                        <!-- Icono -->
                        <LinearLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/circle_orange_light"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                app:srcCompat="@drawable/ic_business"
                                app:tint="#F68031" />
                        </LinearLayout>

                        <!-- Texto -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/account_type_provider_role"
                                android:textColor="#2D2D2D"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/inclusive_sans" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/account_type_provider_role_description"
                                android:textColor="#9E9E9E"
                                android:textSize="12sp"
                                android:fontFamily="@font/inclusive_sans" />
                        </LinearLayout>

                        <!-- Check indicator -->
                        <ImageView
                            android:id="@+id/checkProvider"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:visibility="gone"
                            app:srcCompat="@drawable/ic_check_circle"
                            app:tint="#F68031" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Indicador de pasos -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="32dp"
                        android:layout_height="6dp"
                        android:background="@drawable/step_inactive"
                        android:layout_marginEnd="6dp" />

                    <View
                        android:layout_width="32dp"
                        android:layout_height="6dp"
                        android:background="@drawable/step_active"
                        android:layout_marginEnd="6dp" />

                    <View
                        android:layout_width="32dp"
                        android:layout_height="6dp"
                        android:background="@drawable/step_inactive" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/account_type_step"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp"
                    android:fontFamily="@font/inclusive_sans"
                    android:layout_marginBottom="20dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNext"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/register_button_next"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/inclusive_sans"
                    app:backgroundTint="#BDBDBD"
                    app:cornerRadius="16dp"
                    android:enabled="false" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
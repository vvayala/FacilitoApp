<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".fragments.MyRequestsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="120dp">

        <TextView
            android:id="@+id/txtMyRequestsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inclusive_sans"
            android:text="Mis solicitudes"
            android:textColor="@color/orange_primary"
            android:textSize="38sp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_my_request_bg"
            android:padding="12dp">

            <ImageView
                android:id="@+id/imgRequestUser1"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:contentDescription="@string/usuario"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/icon_user" />

            <TextView
                android:id="@+id/txtRequestName1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="@font/inclusive_sans"
                android:text="Mecánica General - Juan Mecánico"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/imgRequestUser1"
                app:layout_constraintTop_toTopOf="@+id/imgRequestUser1" />

            <TextView
                android:id="@+id/txtRequestCategory1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/inclusive_sans"
                android:text="Carpintería"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/txtRequestName1"
                app:layout_constraintTop_toBottomOf="@+id/txtRequestName1" />

            <TextView
                android:id="@+id/txtRequestDesc1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/inclusive_sans"
                android:text="Necesito un par de muebles para mi casa ya que me acabo de mudar"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/imgRequestUser1" />

            <Button
                android:id="@+id/btnViewRequest1"
                android:layout_width="124dp"
                android:layout_height="44dp"
                android:background="@drawable/button_view_request_bg"
                android:fontFamily="@font/inclusive_sans"
                android:text="Detalles"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                app:backgroundTint="@null"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>


<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Avatar -->
        <ImageView
            android:id="@+id/imgChatAvatar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/icon_user_purple"
            android:background="@drawable/circle_bg_purple"
            android:padding="10dp"
            android:contentDescription="@null"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Business name -->
        <TextView
            android:id="@+id/txtChatBusinessName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:textColor="@color/deep_purple"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/imgChatAvatar"
            app:layout_constraintEnd_toStartOf="@id/txtChatDate"
            app:layout_constraintTop_toTopOf="@id/imgChatAvatar" />

        <!-- Service name -->
        <TextView
            android:id="@+id/txtChatServiceName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_dark"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:alpha="0.7"
            app:layout_constraintStart_toEndOf="@id/imgChatAvatar"
            app:layout_constraintEnd_toStartOf="@id/txtChatDate"
            app:layout_constraintTop_toBottomOf="@id/txtChatBusinessName" />

        <!-- Date -->
        <TextView
            android:id="@+id/txtChatDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_dark"
            android:textSize="11sp"
            android:alpha="0.5"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/imgChatAvatar" />

        <!-- Chevron -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_right"
            android:alpha="0.4"
            android:contentDescription="@null"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/imgChatAvatar" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
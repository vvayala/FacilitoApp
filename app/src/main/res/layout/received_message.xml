<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:id="@+id/txtUsuarioRecibido"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Contacto"
        android:textStyle="bold"
        android:textColor="#311845"
        android:paddingBottom="4dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/iconRecibido"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="6dp"
            android:src="@drawable/icon_user"/>

        <TextView
            android:id="@+id/txtMensajeRecibido"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:background="@color/gray_secondary"
            android:elevation="2dp"
            android:padding="12dp"
            android:radius="12dp"
            android:text="Mensaje recibido"
            android:textColor="#000000"
            android:textSize="16sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtHoraRecibido"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="14:46"
        android:textSize="12sp"
        android:textColor="#888888"
        android:paddingTop="2dp"/>
</LinearLayout>

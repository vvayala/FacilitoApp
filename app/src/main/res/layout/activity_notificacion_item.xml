<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:background="#FFFFFF"
    android:layout_margin="6dp"
    android:elevation="2dp"
    tools:context=".NotificacionItem">

    <ImageView
        android:id="@+id/imgIcono"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="@string/titulo_notificacion"
        android:src="@drawable/icon_notification"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <ImageView
        android:id="@+id/imgCerrar"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/icon_close"
        android:contentDescription="@string/cerrar_notificacion"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/titulo_notificacion"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="#000000"
        app:layout_constraintTop_toTopOf="@id/imgIcono"
        app:layout_constraintStart_toEndOf="@id/imgIcono"
        app:layout_constraintEnd_toStartOf="@id/imgCerrar"
        android:layout_marginStart="8dp"/>

    <TextView
        android:id="@+id/txtMensaje"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"
        android:text="@string/detalles"
        android:textColor="#333333"
        android:textSize="14sp"
        app:layout_constraintEnd_toStartOf="@id/imgCerrar"
        app:layout_constraintStart_toEndOf="@id/imgIcono"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo" />

    <TextView
        android:id="@+id/txtFecha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/dummy_date"
        android:textSize="12sp"
        android:textColor="#888888"
        app:layout_constraintTop_toBottomOf="@id/txtMensaje"
        app:layout_constraintStart_toEndOf="@id/imgIcono"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
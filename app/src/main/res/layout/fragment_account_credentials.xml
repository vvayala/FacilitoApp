<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:paddingBottom="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Título -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/account_credentials_title"
                    android:textColor="@color/text_dark"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inclusive_sans" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="24dp"
                    android:text="@string/account_credentials_description"
                    android:textColor="#9E9E9E"
                    android:textSize="13sp"
                    android:fontFamily="@font/inclusive_sans" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EDE7F6"
                    android:layout_marginBottom="20dp" />

                <!-- Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#7640BD"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inclusive_sans"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutEmail"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxBackgroundColor="#F8F4FF"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#7640BD"
                    app:hintEnabled="false"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="#7640BD">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/txtEmail"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="@string/account_credentials_email_hint"
                        android:inputType="textEmailAddress"
                        android:maxLength="50"
                        android:paddingStart="14dp"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:fontFamily="@font/inclusive_sans" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textColor="#7640BD"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inclusive_sans"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutPassword"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxBackgroundColor="#F8F4FF"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#7640BD"
                    app:hintEnabled="false"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="#7640BD"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#7640BD">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/txtPassword"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="@string/account_credentials_password_hint"
                        android:inputType="textPassword"
                        android:maxLength="50"
                        android:paddingStart="14dp"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:fontFamily="@font/inclusive_sans" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Confirm Password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirm Password"
                    android:textColor="#7640BD"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inclusive_sans"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutConfirmPassword"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:boxBackgroundColor="#F8F4FF"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#7640BD"
                    app:hintEnabled="false"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="#7640BD"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#7640BD">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/txtConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="@string/account_credentials_confirm_password_hint"
                        android:inputType="textPassword"
                        android:maxLength="50"
                        android:paddingStart="14dp"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:fontFamily="@font/inclusive_sans" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password match indicator -->
                <TextView
                    android:id="@+id/txtPasswordError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Passwords do not match"
                    android:textColor="#E53935"
                    android:textSize="12sp"
                    android:fontFamily="@font/inclusive_sans"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone" />

                <!-- Password strength bar -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/account_credentials_password_strength"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"
                    android:fontFamily="@font/inclusive_sans"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:layout_marginBottom="20dp">

                    <View
                        android:id="@+id/strengthBar1"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/step_inactive"
                        android:backgroundTint="#BDBDBD" />

                    <View
                        android:id="@+id/strengthBar2"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/step_inactive"
                        android:backgroundTint="#BDBDBD" />

                    <View
                        android:id="@+id/strengthBar3"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/step_inactive"
                        android:backgroundTint="#BDBDBD" />
                </LinearLayout>

                <!-- Step indicator -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="32dp"
                        android:layout_height="6dp"
                        android:background="@drawable/step_inactive"
                        android:layout_marginEnd="6dp" />

                    <View
                        android:layout_width="32dp"
                        android:layout_height="6dp"
                        android:background="@drawable/step_inactive"
                        android:layout_marginEnd="6dp" />

                    <View
                        android:layout_width="32dp"
                        android:layout_height="6dp"
                        android:background="@drawable/step_active" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/account_credentials_step"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp"
                    android:fontFamily="@font/inclusive_sans"
                    android:layout_marginBottom="20dp" />

                <!-- Botón final -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/register_button_create"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/inclusive_sans"
                    app:backgroundTint="#F68031"
                    app:cornerRadius="16dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/inclusive_sans"
            android:gravity="center"
            android:text="Al registrarte aceptas nuestros Términos y Condiciones"
            android:textColor="#9E9E9E"
            android:textSize="11sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
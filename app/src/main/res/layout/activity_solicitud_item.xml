<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/itemSolicitudLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="#FFFFFF"
    android:layout_margin="6dp"
    android:elevation="2dp"
    tools:context=".SolicitudItem">

    <ImageView
        android:id="@+id/imgProveedor"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/icon_user"
        android:contentDescription="@string/proveedor"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/txtNombreProveedor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="@string/nombreEjemplo"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="#000000"
        app:layout_constraintTop_toTopOf="@id/imgProveedor"
        app:layout_constraintStart_toEndOf="@id/imgProveedor"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtServicio"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="@string/carpinteria"
        android:textSize="14sp"
        android:textColor="#7640BD"
        app:layout_constraintTop_toBottomOf="@id/txtNombreProveedor"
        app:layout_constraintStart_toEndOf="@id/imgProveedor"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtFecha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/fechaEjemplo"
        android:textSize="12sp"
        android:textColor="#888888"
        app:layout_constraintTop_toBottomOf="@id/imgProveedor"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/txtEstado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:padding="4dp"
        android:text="@string/estadoPendiente"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:background="#F68031"
        app:layout_constraintTop_toBottomOf="@id/imgProveedor"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtDescripcion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/descripcion_problema"
        android:textSize="14sp"
        android:textColor="#333333"
        android:maxLines="2"
        android:ellipsize="end"
        app:layout_constraintTop_toBottomOf="@id/txtFecha"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>